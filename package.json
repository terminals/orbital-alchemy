{
  "name": "orbital-command",
  "version": "0.1.0",
  "description": "Orbital Command — mission control dashboard for Claude Code projects",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "project-management",
    "kanban",
    "mission-control",
    "dashboard",
    "workflow",
    "ai-agents",
    "scope-management",
    "sprint",
    "devtools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SakaraLabs/orbital-command.git"
  },
  "homepage": "https://github.com/SakaraLabs/orbital-command#readme",
  "bugs": {
    "url": "https://github.com/SakaraLabs/orbital-command/issues"
  },
  "bin": {
    "orbital": "bin/orbital.js"
  },
  "files": [
    "bin/",
    "dist/",
    "server/",
    "shared/",
    "src/",
    "templates/",
    "schemas/",
    "scripts/",
    "index.html",
    "vite.config.ts",
    "tailwind.config.js",
    "postcss.config.js",
    "tsconfig.json",
    "tsconfig.server.json",
    "components.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "orbital dev",
    "dev:local": "trap 'lsof -ti:4444,4445 | xargs kill 2>/dev/null' EXIT; concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "npx vite build",
    "build:server": "npx tsc -p tsconfig.server.json",
    "typecheck": "npx tsc --noEmit && npx tsc --noEmit -p tsconfig.server.json",
    "prepare": "npm run typecheck && npm run build && npm run build:server",
    "prepublishOnly": "npm run typecheck && npm run build && npm run build:server",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "date-fns": "^4.1.0",
    "express": "^4.21.2",
    "framer-motion": "^11.15.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.2",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
