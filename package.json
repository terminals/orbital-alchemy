{
  "name": "orbital-command",
  "version": "1.1.3",
  "description": "Orbital Command — mission control dashboard for Claude Code projects",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "project-management",
    "kanban",
    "mission-control",
    "dashboard",
    "workflow",
    "ai-agents",
    "scope-management",
    "sprint",
    "devtools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SakaraLabs/orbital-command.git"
  },
  "homepage": "https://github.com/SakaraLabs/orbital-command#readme",
  "bugs": {
    "url": "https://github.com/SakaraLabs/orbital-command/issues"
  },
  "bin": {
    "orbital": "bin/orbital.js"
  },
  "files": [
    "bin/",
    "dist/",
    "server/",
    "shared/",
    "templates/",
    "schemas/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "orbital dev",
    "dev:local": "trap 'lsof -ti:4444,4445 | xargs kill 2>/dev/null' EXIT; concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:launch": "trap 'lsof -ti:4444,4445 | xargs kill 2>/dev/null' EXIT; concurrently -n central,client -c magenta,green \"ORBITAL_LAUNCH_MODE=central ORBITAL_SERVER_PORT=4444 tsx watch server/launch.ts\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "./node_modules/.bin/vite build",
    "build:server": "./node_modules/.bin/tsc -p tsconfig.server.json",
    "typecheck": "./node_modules/.bin/tsc --noEmit && ./node_modules/.bin/tsc --noEmit -p tsconfig.server.json",
    "validate": "npm run typecheck && npm run test && npm run build && npm run build:server",
    "release": "./scripts/release.sh",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run validate",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "better-sqlite3": "^12.0.0",
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@xyflow/react": "^12.10.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.2",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.2.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
