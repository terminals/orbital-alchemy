{
  "name": "Development",
  "version": 1,
  "lists": [
    { "id": "backlog", "label": "Backlog", "order": 0, "color": "230 99% 67%", "hex": "#536dfe", "hasDirectory": true, "isEntryPoint": true },
    { "id": "implementing", "label": "Implementing", "order": 1, "color": "40 100% 50%", "hex": "#ffaa00", "hasDirectory": true, "sessionKey": "implement" },
    { "id": "review", "label": "Review", "order": 2, "color": "263 69% 50%", "hex": "#6b26d9", "hasDirectory": true, "sessionKey": "reviewGate" },
    { "id": "completed", "label": "Completed", "order": 3, "color": "174 70% 42%", "hex": "#20b6aa", "hasDirectory": true },
    { "id": "dev", "label": "Dev", "order": 4, "color": "197 100% 63%", "hex": "#42c3ff", "hasDirectory": true, "gitBranch": "dev" }
  ],
  "edges": [
    { "from": "backlog", "to": "implementing", "direction": "forward", "command": "/scope implement {id}", "confirmLevel": "quick", "label": "Start Implementing", "description": "Opens a Claude session running /scope implement.", "dispatchOnly": true },
    { "from": "implementing", "to": "review", "direction": "forward", "command": "/scope review-gate {id}", "confirmLevel": "full", "label": "Run Review Gate", "description": "Launches formal review gate.", "skipServerTransition": true, "dispatchOnly": true },
    { "from": "review", "to": "completed", "direction": "forward", "command": "/work save", "confirmLevel": "full", "label": "Commit", "description": "Commits scope work to feature branch.", "skipServerTransition": true, "dispatchOnly": true },
    { "from": "completed", "to": "dev", "direction": "forward", "command": "/git pr-dev", "confirmLevel": "full", "label": "Merge to Dev", "description": "Merges feature branch into dev.", "dispatchOnly": true },
    { "from": "review", "to": "implementing", "direction": "backward", "command": null, "confirmLevel": "quick", "label": "Back to Implementing", "description": "Re-opens implementation to address review findings.", "dispatchOnly": false },
    { "from": "completed", "to": "implementing", "direction": "backward", "command": null, "confirmLevel": "quick", "label": "Back to Implementing", "description": "Re-opens implementation to fix issues.", "dispatchOnly": false }
  ],
  "hooks": [],
  "eventInference": [],
  "allowedCommandPrefixes": ["/scope ", "/work ", "/git ", "/test "],
  "terminalStatuses": ["dev"],
  "commitBranchPatterns": "^(dev|feat/|fix/|scope/|chore/)"
}
