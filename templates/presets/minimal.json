{
  "name": "Minimal",
  "version": 1,
  "lists": [
    { "id": "todo", "label": "To Do", "order": 0, "color": "230 99% 67%", "hex": "#536dfe", "hasDirectory": true, "isEntryPoint": true },
    { "id": "in-progress", "label": "In Progress", "order": 1, "color": "40 100% 50%", "hex": "#ffaa00", "hasDirectory": true },
    { "id": "done", "label": "Done", "order": 2, "color": "153 100% 39%", "hex": "#00c76d", "hasDirectory": true }
  ],
  "edges": [
    { "from": "todo", "to": "in-progress", "direction": "forward", "command": null, "confirmLevel": "quick", "label": "Start", "description": "Move to in progress.", "dispatchOnly": false },
    { "from": "in-progress", "to": "done", "direction": "forward", "command": null, "confirmLevel": "quick", "label": "Complete", "description": "Mark as done.", "dispatchOnly": false }
  ],
  "hooks": [],
  "eventInference": [],
  "allowedCommandPrefixes": ["/scope ", "/work ", "/git "],
  "terminalStatuses": ["done"],
  "commitBranchPatterns": "^(main|feat/|fix/|chore/)"
}
