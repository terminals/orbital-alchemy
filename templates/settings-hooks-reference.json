{
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.moralis.com)",
      "WebSearch",
      "Bash(npm test:*)",
      "Bash(npm run type-check:*)",
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(npx tsc:*)",
      "Bash(npm run lint:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(docker-compose build:*)",
      "Bash(npx eslint:*)",
      "mcp__solana-mcp-server__Solana_Documentation_Search",
      "mcp__solana-mcp-server__Solana_Expert__Ask_For_Help",
      "Bash(git -C /Users/miguel/Code/retailBot diff --cached --name-only)",
      "Bash(npm run validate-templates:*)",
      "Bash(git config:*)",
      "Bash(npm run validate-doc-links:*)",
      "Bash(npm run generate-docs:check:*)",
      "Bash(npm run generate-docs:*)",
      "Skill(data:db-access)",
      "Bash(grep:*)",
      "Bash(npm run check-rules:*)",
      "Bash(claude /doctor)",
      "Skill(implement)",
      "Bash(if grep -rE \"\\\\|\\\\| [''\"\"].*secret\\\\|key\\\\|token\" src --include=\"*.ts\")",
      "Bash(then echo \"❌ Found default secrets\")",
      "Bash(exit 1)",
      "Bash(else echo \"✅ No default secrets\")",
      "Bash(fi)",
      "Skill(reflect)",
      "Bash(git add:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(tail:*)",
      "Bash(find /Users/miguel/Code/retailBot/frontend/src -type f \\\\\\( -name \"*.tsx\" -o -name \"*.ts\" \\\\\\) 2>/dev/null | head -30)",
      "Bash(npx vite:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/init-session.sh",
            "statusMessage": "Initializing session..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/end-session.sh",
            "statusMessage": "Cleaning up session..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-workarounds.sh",
            "statusMessage": "Checking for workaround patterns..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scope-file-sync.sh",
            "statusMessage": "Checking scope file sync..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scope-lifecycle-gate.sh",
            "statusMessage": "Checking scope lifecycle..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scope-create-gate.sh",
            "statusMessage": "Checking scope creation gate..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-trigger.sh",
            "statusMessage": "Checking agent triggers..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-id-enforcer.sh",
            "statusMessage": "Checking session ID in scope..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/phase-verify-reminder.sh",
            "statusMessage": "Checking phase verification..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/blocker-check.sh",
            "statusMessage": "Checking blockers..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dependency-check.sh",
            "statusMessage": "Checking dependencies..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/completion-checklist.sh",
            "statusMessage": "Checking completion..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/review-gate-check.sh",
            "statusMessage": "Checking review gate..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/files-changed-summary.sh",
            "statusMessage": "Checking files summary..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scope-commit-logger.sh",
            "statusMessage": "Logging scope activity..."
          }
        ]
      },
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/exploration-logger.sh",
            "statusMessage": "Tracking exploration..."
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/decision-capture.sh",
            "statusMessage": "Capturing decision..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/time-tracker.sh",
            "statusMessage": "Tracking scope timing..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scope-create-cleanup.sh",
            "statusMessage": "Checking scope creation cleanup..."
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scope-create-tracker.sh",
            "statusMessage": "Tracking skill invocation..."
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scope-gate.sh",
            "statusMessage": "Checking scope creation..."
          }
        ]
      }
    ]
  },
  "outputStyle": "Explanatory"
}
